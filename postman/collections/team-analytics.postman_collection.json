              "raw": "{\r\n  \"eventType\": \"SENSOR_READING\",\r\n  \"eventId\": \"0196fb3d-4ad7-7d1e-9f49-5d5148d2babc\",\r\n  \"deviceId\": \"SENSOR-001\",\r\n  \"metric\": \"temperature\",\r\n  \"value\": 38.5,\r\n  \"unit\": \"celsius\",\r\n  \"timestamp\": \"2026-05-10T08:00:00Z\"\r\n}",
