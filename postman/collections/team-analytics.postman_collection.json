    {
      "name": "04_Boundary_reliability",
      "item": [
        {
          "name": "GET /alerts/recent - Limit Test",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "pm.test(\"Mảng items trả về không vượt quá 1 (Boundary)\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    if(jsonData.items) {\r",
                  "        pm.expect(jsonData.items.length).to.be.at.most(1);\r",
                  "    }\r",
                  "});\r",
                  "pm.test(\"Response time dưới 500ms (Reliability)\", function () {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(500);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{authToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/alerts/recent?limit=1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "alerts",
                "recent"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "1"
                }
              ]
            }
          },
          "response": []
        }
      ]
    },
